{
  "name": "modelica-preview",
  "displayName": "Modelica Graphical Preview",
  "description": "Graphical diagram preview for Modelica .mo files",
  "version": "1.0.1",
  "license": "MIT",
  "publisher": "ThirraFang",
  "repository": {
    "type": "git",
    "url": "https://github.com/Thirra-Fang/modelica-preview.git"
  },
  "bugs": {
    "url": "https://github.com/Thirra-Fang/modelica-preview/issues"
  },
  "homepage": "https://github.com/Thirra-Fang/modelica-preview",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "icon": "assets/modelica-preview-icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "modelica-preview.showPreview",
        "title": "Show Diagram Preview",
        "category": "Modelica",
        "icon": "$(open-preview)"
      }
    ],
    "languages": [
      {
        "id": "modelica",
        "aliases": [
          "Modelica",
          "modelica"
        ],
        "extensions": [
          ".mo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "modelica-preview.showPreview",
          "when": "editorLangId == modelica || resourceExtname == .mo",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "modelica-preview.showPreview",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "editorTextFocus && (editorLangId == modelica || resourceExtname == .mo)"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production && npx vsce package",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
